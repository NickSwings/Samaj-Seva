rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    match /users/{userId} {
  		// Allow any authenticated user to create their initial profile
  		// They just need to be logged in and the ID must match their Auth UID
  		allow create: if request.auth != null && request.auth.uid == userId;

  		// For updates, you can keep the stricter verified check
  		allow update: if isVerified() && request.auth.uid == userId;
  
  		// NGOs still need to read profiles to see volunteer contact info
  		allow read: if isVerified();
		}

    match /tasks/{taskId} {
      allow read: if isVerified();
      allow create: if isVerified() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ngo';
      
      allow update: if isVerified() && (
        request.auth.uid == resource.data.postedBy || 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'volunteer' && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acceptedVolunteers']))
      );

      allow delete: if isVerified() && request.auth.uid == resource.data.postedBy;
    }
  }
}